<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A">

    <!-- Stars background effect -->
    <View
        android:id="@+id/bgView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Frequency badge -->
    <TextView
        android:id="@+id/tvFrequency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="101.1 FM"
        android:textColor="#8888FF"
        android:textSize="14sp"
        android:letterSpacing="0.2"
        android:fontFamily="sans-serif-light"
        app:layout_constraintBottom_toTopOf="@id/tvStationName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="4dp" />

    <!-- Station name -->
    <TextView
        android:id="@+id/tvStationName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SPACE"
        android:textColor="#FFFFFF"
        android:textSize="64sp"
        android:fontFamily="sans-serif-thin"
        android:letterSpacing="0.3"
        app:layout_constraintBottom_toTopOf="@id/tvTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="0dp" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KMGP · Seattle"
        android:textColor="#6666AA"
        android:textSize="12sp"
        android:letterSpacing="0.25"
        android:fontFamily="sans-serif-light"
        app:layout_constraintBottom_toTopOf="@id/pulseRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="56dp" />

    <!-- Pulse ring (decorative) -->
    <View
        android:id="@+id/pulseRing"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/circle_ring"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="0dp" />

    <!-- Play/Pause button -->
    <ImageButton
        android:id="@+id/btnPlayPause"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/circle_button"
        android:src="@android:drawable/ic_media_play"
        android:scaleType="center"
        android:padding="18dp"
        app:layout_constraintTop_toTopOf="@id/pulseRing"
        app:layout_constraintBottom_toBottomOf="@id/pulseRing"
        app:layout_constraintStart_toStartOf="@id/pulseRing"
        app:layout_constraintEnd_toEndOf="@id/pulseRing" />

    <!-- Progress / buffering spinner -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:visibility="gone"
        android:indeterminateTint="#8888FF"
        app:layout_constraintTop_toTopOf="@id/pulseRing"
        app:layout_constraintBottom_toBottomOf="@id/pulseRing"
        app:layout_constraintStart_toStartOf="@id/pulseRing"
        app:layout_constraintEnd_toEndOf="@id/pulseRing" />

    <!-- Status text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap to listen"
        android:textColor="#8888FF"
        android:textSize="13sp"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toBottomOf="@id/pulseRing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp" />

    <!-- Track title -->
    <TextView
        android:id="@+id/tvTrackTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:ellipsize="marquee"
        android:singleLine="true"
        android:marqueeRepeatLimit="marquee_forever"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp" />

    <!-- Artist name -->
    <TextView
        android:id="@+id/tvTrackArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#8888FF"
        android:textSize="13sp"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:ellipsize="end"
        android:singleLine="true"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvTrackTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp" />

    <!-- Bottom links -->
    <LinearLayout
        android:id="@+id/layoutLinks"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="72dp">

        <TextView
            android:id="@+id/btnWebsite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Website"
            android:textColor="#6666CC"
            android:textSize="13sp"
            android:padding="8dp"
            android:background="@drawable/link_bg"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="#333366"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btnDonate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Donate"
            android:textColor="#AA88FF"
            android:textSize="13sp"
            android:padding="8dp"
            android:background="@drawable/link_bg"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
